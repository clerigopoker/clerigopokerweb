# ============================================
# CLÉRIGO POKER — Cloudflare Pages Headers
# Cabeceras de seguridad HTTP de nivel A+
# ============================================

# Todas las páginas
/*
  # HSTS — fuerza HTTPS (1 año + preload)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  
  # Prevenir clickjacking
  X-Frame-Options: DENY
  
  # Prevenir MIME type sniffing
  X-Content-Type-Options: nosniff
  
  # Referrer policy — privacidad
  Referrer-Policy: strict-origin-when-cross-origin
  
  # Permissions Policy — deshabilitar APIs innecesarias
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  
  # Content Security Policy
  # Permite: self, Google Fonts, Google Tag Manager, Google Analytics, WPT tracking
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://www.google-analytics.com https://tracking.wptpartners.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com https://analytics.google.com https://www.googletagmanager.com; frame-src 'self' https://www.googletagmanager.com; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests

# Assets estáticos — cache agresivo
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Imágenes — cache largo
/images/*
  Cache-Control: public, max-age=2592000

# Fonts — cache largo
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
