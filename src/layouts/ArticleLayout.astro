---
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import WptBanner from '@/components/WptBanner.astro';
import { banners } from '@/config/banners';
import { getArticleSchema, getCanonical, getReadingTime } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: { src: string; alt: string; width?: number; height?: number };
  tags?: string[];
  category?: string;
  silo?: string;
  difficulty?: string;
  schemaType?: string;
  rawContent?: string;
  ctaEyebrow?: string;
  ctaHeadline?: string;
  ctaBody?: string;
  ctaCta?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'El Clérigo',
  image,
  tags = [],
  category,
  silo,
  difficulty,
  schemaType = 'Article',
  rawContent = '',
  ctaEyebrow,
  ctaHeadline,
  ctaBody,
  ctaCta,
} = Astro.props;

const readingTime = rawContent ? getReadingTime(rawContent) : 5;
const articleUrl = getCanonical(Astro.url.pathname);

const articleSchema = getArticleSchema({
  title, description, url: articleUrl,
  image: image?.src, pubDate, updatedDate, author, schemaType,
});

const breadcrumbItems = [];
if (silo) {
  const siloNames: Record<string, string> = {
    estrategia: 'Estrategia', psicologia: 'Psicología',
    noticias: 'Noticias', conceptos: 'Conceptos',
  };
  breadcrumbItems.push({ name: siloNames[silo] || silo, url: `/${silo}` });
}
if (category) {
  const categoryNames: Record<string, string> = {
    preflop: 'Pre-Flop', postflop: 'Post-Flop', torneos: 'Torneos',
    'cash-game': 'Cash Game', tilt: 'Tilt', mindset: 'Mindset',
    'bankroll-management': 'Bankroll',
  };
  breadcrumbItems.push({ name: categoryNames[category] || category, url: `/${silo}/${category}` });
}
breadcrumbItems.push({ name: title, url: Astro.url.pathname });

const difficultyLabels: Record<string, { label: string; color: string; bg: string }> = {
  novicio:   { label: '🕯️ Novicio',   color: 'text-success',       bg: 'rgba(46,204,113,0.08)' },
  acolito:   { label: '📖 Acólito',   color: 'text-incense-light', bg: 'rgba(124,111,196,0.08)' },
  sacerdote: { label: '⛪ Sacerdote', color: 'text-gold',          bg: 'rgba(212,168,71,0.08)' },
  obispo:    { label: '👑 Obispo',    color: 'text-blood-light',   bg: 'rgba(196,30,58,0.08)' },
};

const formattedDate = pubDate.toLocaleDateString('es-ES', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  image={image}
  tags={tags}
  ctaVariant="sermon"
  ctaEyebrow={ctaEyebrow}
  ctaHeadline={ctaHeadline}
  ctaBody={ctaBody}
  ctaCta={ctaCta}
>
  <script type="application/ld+json" set:html={articleSchema} />

  <article class="relative">

    <!-- ===== ARTICLE HEADER ===== -->
    <header class="relative overflow-hidden pb-10 pt-10">
      <div class="pointer-events-none absolute left-1/2 top-0 h-[350px] w-[600px] -translate-x-1/2 opacity-[0.04]" style="background: radial-gradient(ellipse, var(--color-gold) 0%, transparent 70%); filter: blur(60px);" aria-hidden="true"></div>

      <div class="relative mx-auto max-w-3xl px-4 sm:px-6">
        <Breadcrumb items={breadcrumbItems} />

        {tags.length > 0 && (
          <div class="mb-5 flex flex-wrap gap-2">
            {tags.slice(0, 4).map((tag) => (
              <span class="rounded-full px-3 py-1 text-[0.6875rem] font-medium" style="background: rgba(124, 111, 196, 0.08); color: var(--color-incense-light); border: 1px solid rgba(124, 111, 196, 0.12);">
                {tag}
              </span>
            ))}
          </div>
        )}

        <h1 class="font-display text-3xl font-extrabold leading-[1.1] text-scripture sm:text-4xl lg:text-[2.75rem]">
          {title}
        </h1>

        <p class="mt-5 text-lg leading-relaxed text-psalm sm:text-xl">{description}</p>

        <!-- Meta bar -->
        <div class="mt-7 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-b border-chalice/15 py-4">
          <div class="flex items-center gap-2">
            <div class="flex h-8 w-8 items-center justify-center rounded-full text-xs" style="background: linear-gradient(135deg, rgba(212,168,71,0.12), rgba(212,168,71,0.04)); border: 1px solid rgba(212,168,71,0.15);">✝</div>
            <span class="text-sm font-medium text-scripture">{author}</span>
          </div>
          <span class="text-chalice-light">·</span>
          <time datetime={pubDate.toISOString()} class="text-sm text-psalm">{formattedDate}</time>
          <span class="text-chalice-light">·</span>
          <span class="text-sm text-psalm">{readingTime} min de lectura</span>
          {difficulty && difficultyLabels[difficulty] && (
            <>
              <span class="text-chalice-light">·</span>
              <span class={`text-sm font-medium ${difficultyLabels[difficulty].color}`} style={`background: ${difficultyLabels[difficulty].bg}; padding: 0.125rem 0.625rem; border-radius: 9999px;`}>
                {difficultyLabels[difficulty].label}
              </span>
            </>
          )}
        </div>
      </div>
    </header>

    <!-- ===== FEATURED IMAGE ===== -->
    {image && (
      <figure class="mx-auto mb-8 max-w-4xl px-4 sm:px-6">
        <div class="overflow-hidden rounded-2xl" style="border: 1px solid rgba(30, 30, 48, 0.6);">
          <img
            src={image.src}
            alt={image.alt}
            width={image.width || 1200}
            height={image.height || 630}
            loading="eager"
            decoding="async"
            class="w-full object-cover"
            style="aspect-ratio: 1.91/1;"
          />
        </div>
      </figure>
    )}

    <!-- ===== BANNER 468x60 — debajo de imagen, solo mobile ===== -->
    <div class="flex flex-col items-center mb-8 px-4 sm:hidden">
      <Fragment set:html={banners.mobileBanner} />
      <p class="mt-1 text-[0.6rem] text-psalm">
        +18 · Juego responsable · Términos en la plataforma
      </p>
    </div>

    <!-- ===== LAYOUT DOS COLUMNAS (desktop) / UNA COLUMNA (mobile) ===== -->
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="flex gap-10">

        <!-- Columna principal — artículo -->
        <div class="min-w-0 flex-1">
          <div class="prose-clerigo">
            <slot />
          </div>

          <!-- End decoration -->

          <!-- Script: inserta banner mobile después del 3er párrafo -->
          <script>
            (function () {
              // Solo en mobile
              if (window.innerWidth >= 640) return;

              const prose = document.querySelector('.prose-clerigo');
              if (!prose) return;

              const paragraphs = prose.querySelectorAll('p');
              if (paragraphs.length < 3) return;

              const banner = document.createElement('div');
              banner.className = 'my-6 flex flex-col items-center';
              banner.innerHTML = `
                <a href="https://tracking.wptpartners.com/visit/?bta=35660&nci=13207" target="_top">
                  <img border="0" src="https://wptpartners.ck-cdn.com/tn/serve/?cid=501476" width="300" height="250" alt="WPT Global" loading="lazy" />
                </a>
                <p style="font-size:0.6rem; margin-top:0.5rem; text-align:center; color: var(--color-psalm);">
                  +18 · Juego responsable · Términos en la plataforma
                </p>
              `;

              paragraphs[2].insertAdjacentElement('afterend', banner);
            })();
          </script>
          <div class="mt-12 mb-8 text-center">
            <div class="divider-sacred">
              <span class="text-sm text-psalm">♠ ♥ ♦ ♣</span>
            </div>
            {silo && (
              <a
                href={`/${silo}`}
                class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-psalm transition-all hover:gap-3 hover:text-gold"
              >
                <span aria-hidden="true">←</span>
                Volver a {silo === 'estrategia' ? 'Estrategia' : silo === 'psicologia' ? 'Psicología' : silo === 'noticias' ? 'Noticias' : 'Conceptos'}
              </a>
            )}
          </div>
        </div>

        <!-- Columna sidebar — solo desktop (lg+) -->
        <aside class="hidden lg:block w-[300px] shrink-0">
          <div class="sticky top-24">
            <!-- Banner 300x600 -->
            <div class="flex justify-center">
              <Fragment set:html={banners.sidebar} />
            </div>
            <p class="mt-2 text-center text-[0.6rem] text-psalm">
              +18 · Juego responsable · Términos en la plataforma
            </p>
          </div>
        </aside>

      </div>
    </div>

  </article>
</BaseLayout>