---
/**
 * ArticleLayout.astro — Layout para artículos de contenido
 * Extiende BaseLayout con: breadcrumbs, schema Article,
 * tiempo de lectura, navegación entre artículos
 */
import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import { getArticleSchema, getCanonical, getReadingTime } from '@/utils/seo';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  image?: { src: string; alt: string; width?: number; height?: number };
  tags?: string[];
  category?: string;
  silo?: string;
  difficulty?: string;
  schemaType?: string;
  /** Raw content for reading time estimation */
  rawContent?: string;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  author = 'El Clérigo',
  image,
  tags = [],
  category,
  silo,
  difficulty,
  schemaType = 'Article',
  rawContent = '',
} = Astro.props;

const readingTime = rawContent ? getReadingTime(rawContent) : 5;
const articleUrl = getCanonical(Astro.url.pathname);

const articleSchema = getArticleSchema({
  title,
  description,
  url: articleUrl,
  image: image?.src,
  pubDate,
  updatedDate,
  author,
  schemaType,
});

// Build breadcrumb items
const breadcrumbItems = [];
if (silo) {
  const siloNames: Record<string, string> = {
    estrategia: 'Estrategia',
    psicologia: 'Psicología',
    noticias: 'Noticias',
    conceptos: 'Conceptos',
  };
  breadcrumbItems.push({
    name: siloNames[silo] || silo,
    url: `/${silo}`,
  });
}
if (category) {
  const categoryNames: Record<string, string> = {
    preflop: 'Pre-Flop',
    postflop: 'Post-Flop',
    torneos: 'Torneos',
    'cash-game': 'Cash Game',
    tilt: 'Tilt',
    mindset: 'Mindset',
    'bankroll-management': 'Bankroll',
  };
  breadcrumbItems.push({
    name: categoryNames[category] || category,
    url: `/${silo}/${category}`,
  });
}
breadcrumbItems.push({ name: title, url: Astro.url.pathname });

// Difficulty labels con personalidad
const difficultyLabels: Record<string, { label: string; color: string }> = {
  novicio: { label: '🕯️ Novicio', color: 'text-success' },
  acolito: { label: '📖 Acólito', color: 'text-incense-light' },
  sacerdote: { label: '⛪ Sacerdote', color: 'text-gold' },
  obispo: { label: '👑 Obispo', color: 'text-blood-light' },
};
---

<BaseLayout
  title={title}
  description={description}
  type="article"
  pubDate={pubDate}
  updatedDate={updatedDate}
  author={author}
  image={image}
  tags={tags}
  ctaVariant="sermon"
>
  <!-- Article Schema.org -->
  <script type="application/ld+json" set:html={articleSchema} />

  <article class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <Breadcrumb items={breadcrumbItems} />

    <!-- Article Header -->
    <header class="mb-10">
      {tags.length > 0 && (
        <div class="mb-4 flex flex-wrap gap-2">
          {tags.slice(0, 4).map((tag) => (
            <span class="rounded-full bg-incense/10 px-3 py-0.5 text-xs font-medium text-incense-light">
              {tag}
            </span>
          ))}
        </div>
      )}

      <h1 class="font-display text-3xl font-bold leading-tight text-scripture sm:text-4xl lg:text-5xl">
        {title}
      </h1>

      <p class="mt-4 text-lg text-psalm">{description}</p>

      <!-- Meta line -->
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-whisper">
        <span>Por <strong class="text-gold">{author}</strong></span>
        <span>·</span>
        <time datetime={pubDate.toISOString()}>
          {pubDate.toLocaleDateString('es-ES', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <span>·</span>
        <span>{readingTime} min de lectura</span>
        {difficulty && difficultyLabels[difficulty] && (
          <>
            <span>·</span>
            <span class={difficultyLabels[difficulty].color}>
              {difficultyLabels[difficulty].label}
            </span>
          </>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    {image && (
      <figure class="mb-10 overflow-hidden rounded-xl">
        <img
          src={image.src}
          alt={image.alt}
          width={image.width || 1200}
          height={image.height || 630}
          loading="eager"
          decoding="async"
          class="w-full object-cover"
        />
      </figure>
    )}

    <!-- Article Content -->
    <div class="prose-clerigo">
      <slot />
    </div>
  </article>
</BaseLayout>
