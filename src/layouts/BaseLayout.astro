---
/**
 * BaseLayout.astro — Layout maestro del Clérigo Poker
 * Envuelve TODAS las páginas. Incluye:
 * - SEO Head (meta, OG, Twitter)
 * - Header + Footer
 * - CTA WPT Global
 * - Analytics (GTM)
 * - Schema.org WebSite
 */
import SEOHead from '@/components/SEOHead.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import CTAWpt from '@/components/CTAWpt.astro';
import CookieConsent from '@/components/CookieConsent.astro';
import AgeGate from '@/components/AgeGate.astro';
import Analytics from '@/components/Analytics.astro';
import { getWebSiteSchema, type SEOProps } from '@/utils/seo';
import '@/styles/global.css';
import WptBanner from '@/components/WptBanner.astro';

interface Props extends SEOProps {
  /** Si true, no muestra el CTA de WPT al final */
  hideCTA?: boolean;
  /** Variante del CTA */
  ctaVariant?: 'default' | 'sermon' | 'confesion';
  /** Copy personalizado del CTA (sobreescribe variante) */
  ctaEyebrow?: string;
  ctaHeadline?: string;
  ctaBody?: string;
  ctaCta?: string;
}

const {
  hideCTA = false,
  ctaVariant = 'default',
  ctaEyebrow,
  ctaHeadline,
  ctaBody,
  ctaCta,
  ...seoProps
} = Astro.props;

const websiteSchema = getWebSiteSchema();
---

<!doctype html>
<html lang="es" dir="ltr">
  <head>
    <SEOHead {...seoProps} />
    <Analytics />
    <!-- Schema.org WebSite (global) -->
    <script type="application/ld+json" set:html={websiteSchema} />
  </head>
  <body class="min-h-screen bg-abyss text-scripture antialiased">
    <!-- GTM noscript fallback -->
    <noscript>
      <iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-TVT4NVTD"
        height="0"
        width="0"
        style="display:none;visibility:hidden"
        title="Google Tag Manager"
      ></iframe>
    </noscript>

    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-lg focus:bg-gold focus:px-4 focus:py-2 focus:text-abyss focus:font-bold"
    >
      Saltar al contenido principal
    </a>

    <Header />

    <main id="main-content" class="pt-16">
      <slot />
    </main>

    {!hideCTA && <CTAWpt variant={ctaVariant} customEyebrow={ctaEyebrow} customHeadline={ctaHeadline} customBody={ctaBody} customCta={ctaCta} />}
	<WptBanner placement="global" />
    <Footer />

    <AgeGate />
    <CookieConsent />
  </body>
</html>
