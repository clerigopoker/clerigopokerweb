---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';

const allPosts = await getCollection('psicologia', ({ data }) => !data.draft && data.category === 'bankroll-management');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Bankroll Management"
  description="Guías de gestión de bankroll para póker: cuántos buy-ins necesitas, cómo subir de nivel y por qué la disciplina financiera es más importante que el talento."
>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[
      { name: 'Psicología', url: '/psicologia' },
      { name: 'Bankroll', url: '/psicologia/bankroll-management' },
    ]} />
    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-scripture sm:text-5xl">
        🧠 <span class="text-sacred">Bankroll Management</span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-psalm">
        El dinero sagrado. Aquí aprenderás a proteger tu bankroll como un templo,
        a subir de nivel sin arruinarte, y a sobrevivir la varianza como un verdadero devoto.
      </p>
    </header>
    {posts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/psicologia/${post.id}`}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            difficulty={post.data.difficulty}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="card-altar text-center py-12">
        <p class="text-psalm text-lg">🕯️ Los primeros sermones de bankroll están en camino...</p>
      </div>
    )}
  </section>
</BaseLayout>
