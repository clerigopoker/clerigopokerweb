---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
---

<BaseLayout
  title="Bankroll Management"
  description="Gestión de bankroll para jugadores de póker: cuántos buy-ins necesitas, cuándo subir de nivel, y por qué el bankroll management es el mandamiento más sagrado."
>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[
      { name: 'Psicología', url: '/psicologia' },
      { name: 'Bankroll Management', url: '/psicologia/bankroll-management' },
    ]} />
    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-scripture sm:text-5xl">
        💰 <span class="text-sacred">Bankroll Management</span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-psalm">
        El mandamiento más sagrado y el más ignorado. Cuántos buy-ins necesitas,
        cuándo subir de stakes, y por qué el jugador que no respeta su bankroll
        está firmando su propia excomunión.
      </p>
    </header>
    <div class="card-altar text-center py-12">
      <p class="text-psalm text-lg">🕯️ Los cálculos sagrados están en preparación...</p>
    </div>
  </section>
</BaseLayout>
