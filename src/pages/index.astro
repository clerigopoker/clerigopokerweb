---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DailyScripture from '@/components/DailyScripture.astro';
---

<BaseLayout
  title={undefined}
  description="El portal de póker en español donde la estrategia es religión. Guías de estrategia, psicología del juego y noticias para devotos del green felt."
>
  <!-- ===== HERO ===== -->
  <section class="relative overflow-hidden px-4 py-24 sm:py-36 lg:py-44">
    <!-- Atmospheric glows -->
    <div class="pointer-events-none absolute inset-0" aria-hidden="true">
      <!-- Central gold glow -->
      <div class="absolute left-1/2 top-1/3 h-[500px] w-[700px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-20" style="background: radial-gradient(circle, rgba(212, 168, 71, 0.4) 0%, transparent 65%); filter: blur(80px);"></div>
      <!-- Left accent -->
      <div class="absolute -left-32 top-1/2 h-[400px] w-[400px] rounded-full opacity-10" style="background: radial-gradient(circle, var(--color-incense) 0%, transparent 70%); filter: blur(100px);"></div>
      <!-- Right accent -->
      <div class="absolute -right-32 top-1/4 h-[300px] w-[300px] rounded-full opacity-8" style="background: radial-gradient(circle, var(--color-blood) 0%, transparent 70%); filter: blur(100px);"></div>
      <!-- Grid pattern overlay -->
      <div class="absolute inset-0 opacity-[0.015]" style="background-image: linear-gradient(rgba(212, 168, 71, 0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(212, 168, 71, 0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>

    <div class="relative mx-auto max-w-4xl text-center">
      <!-- Eyebrow -->
      <div class="animate-fade-in">
        <span class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-[0.2em]" style="background: rgba(212, 168, 71, 0.06); border: 1px solid rgba(212, 168, 71, 0.15); color: var(--color-gold);">
          <span class="h-1.5 w-1.5 rounded-full bg-gold animate-glow"></span>
          Bienvenido a la Parroquia
        </span>
      </div>

      <!-- Headline -->
      <h1 class="mt-8 font-display text-5xl font-extrabold leading-[1.05] sm:text-6xl lg:text-7xl animate-fade-in animate-fade-in-delay-1">
        Donde la Estrategia<br />
        <span class="text-sacred">es Religión</span>
      </h1>

      <!-- Subtitle -->
      <p class="mx-auto mt-7 max-w-2xl text-lg leading-relaxed text-psalm sm:text-xl animate-fade-in animate-fade-in-delay-2">
        Estrategia sacra, psicología sin filtros y noticias frescas del green felt.
        Este no es un portal de póker más. Esto es un <strong class="text-gold font-semibold">acto de fe</strong>.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row animate-fade-in animate-fade-in-delay-3">
        <a href="/estrategia" class="btn-communion">
          Comenzar la Liturgia
        </a>
        <a href="/sobre" class="btn-vesper">
          ¿Quién es el Clérigo?
        </a>
      </div>

      <!-- Social proof line -->
      <p class="mt-12 text-xs tracking-wider text-whisper animate-fade-in animate-fade-in-delay-4">
        ♠ &nbsp; ESTRATEGIA &nbsp; · &nbsp; PSICOLOGÍA &nbsp; · &nbsp; NOTICIAS &nbsp; · &nbsp; COMUNIDAD &nbsp; ♣
      </p>
    </div>
  </section>

  <!-- ===== ESCRITURA DEL DÍA ===== -->
  <DailyScripture />

  <!-- ===== PILARES / SILOS ===== -->
  <section class="relative mx-auto max-w-6xl px-4 py-20">
    <!-- Section divider -->
    <div class="divider-sacred mb-14">
      <span class="font-display text-xs font-bold uppercase tracking-[0.25em] text-gold/70">
        Los Pilares de la Fe
      </span>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
      <!-- Estrategia -->
      <a href="/estrategia" class="card-altar group block overflow-hidden p-0">
        <div class="relative h-40 overflow-hidden">
          <img src="/images/pilares/estrategia.avif" alt="Estrategia de póker — fichas y cartas sobre green felt" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(8,8,13,0.95) 0%, rgba(8,8,13,0.3) 50%, transparent 100%);"></div>
          <div class="absolute bottom-3 left-4 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg text-base" style="background: rgba(212,168,71,0.15); border: 1px solid rgba(212,168,71,0.25); backdrop-filter: blur(8px);">♠</span>
            <h2 class="font-display text-lg font-bold text-white drop-shadow-lg">Estrategia</h2>
          </div>
        </div>
        <div class="p-4 pt-3">
          <p class="text-sm leading-relaxed text-psalm">
            Pre-flop, post-flop, torneos y cash. Los mandamientos tácticos
            que separan a los pecadores de los santos.
          </p>
          <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-gold/60 transition-all group-hover:gap-2 group-hover:text-gold">
            Explorar <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      <!-- Psicología -->
      <a href="/psicologia" class="card-altar group block overflow-hidden p-0">
        <div class="relative h-40 overflow-hidden">
          <img src="/images/pilares/psicologia.avif" alt="Psicología del póker — mente y control emocional" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(8,8,13,0.95) 0%, rgba(8,8,13,0.3) 50%, transparent 100%);"></div>
          <div class="absolute bottom-3 left-4 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg text-base" style="background: rgba(124,111,196,0.15); border: 1px solid rgba(124,111,196,0.25); backdrop-filter: blur(8px);">🧠</span>
            <h2 class="font-display text-lg font-bold text-white drop-shadow-lg">Psicología</h2>
          </div>
        </div>
        <div class="p-4 pt-3">
          <p class="text-sm leading-relaxed text-psalm">
            Tilt, mindset y bankroll management. La batalla más dura
            se libra entre tus orejas, no en las cartas.
          </p>
          <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-incense/60 transition-all group-hover:gap-2 group-hover:text-incense-light">
            Explorar <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      <!-- Noticias -->
      <a href="/noticias" class="card-altar group block overflow-hidden p-0">
        <div class="relative h-40 overflow-hidden">
          <img src="/images/pilares/noticias.avif" alt="Noticias de póker — actualidad del green felt" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(8,8,13,0.95) 0%, rgba(8,8,13,0.3) 50%, transparent 100%);"></div>
          <div class="absolute bottom-3 left-4 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg text-base" style="background: rgba(196,30,58,0.15); border: 1px solid rgba(196,30,58,0.25); backdrop-filter: blur(8px);">📰</span>
            <h2 class="font-display text-lg font-bold text-white drop-shadow-lg">Noticias</h2>
          </div>
        </div>
        <div class="p-4 pt-3">
          <p class="text-sm leading-relaxed text-psalm">
            La actualidad del poker mundial filtrada por la perspectiva
            irreverente del Clérigo. Sin rodeos, sin PR corporativo.
          </p>
          <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-blood/60 transition-all group-hover:gap-2 group-hover:text-blood-light">
            Explorar <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      <!-- Conceptos -->
      <a href="/conceptos" class="card-altar group block overflow-hidden p-0">
        <div class="relative h-40 overflow-hidden">
          <img src="/images/pilares/conceptos.avif" alt="Conceptos de póker — glosario sagrado del green felt" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(8,8,13,0.95) 0%, rgba(8,8,13,0.3) 50%, transparent 100%);"></div>
          <div class="absolute bottom-3 left-4 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg text-base" style="background: rgba(212,168,71,0.15); border: 1px solid rgba(212,168,71,0.25); backdrop-filter: blur(8px);">📖</span>
            <h2 class="font-display text-lg font-bold text-white drop-shadow-lg">Conceptos</h2>
          </div>
        </div>
        <div class="p-4 pt-3">
          <p class="text-sm leading-relaxed text-psalm">
            El diccionario sagrado del póker. Cada término explicado con la
            profundidad que merece, no con dos líneas de Wikipedia.
          </p>
          <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-gold/60 transition-all group-hover:gap-2 group-hover:text-gold">
            Explorar <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>

      <!-- Herramientas -->
      <a href="/herramientas" class="card-altar group block overflow-hidden p-0 sm:col-span-2 lg:col-span-2">
        <div class="relative h-40 overflow-hidden">
          <img src="/images/pilares/herramientas.avif" alt="Herramientas de póker — calculadoras y quizzes del Clérigo" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-110" loading="lazy" />
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(8,8,13,0.95) 0%, rgba(8,8,13,0.3) 50%, transparent 100%);"></div>
          <div class="absolute bottom-3 left-4 flex items-center gap-2">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg text-base" style="background: rgba(212,168,71,0.15); border: 1px solid rgba(212,168,71,0.25); backdrop-filter: blur(8px);">🛠️</span>
            <h2 class="font-display text-lg font-bold text-white drop-shadow-lg">Herramientas</h2>
          </div>
        </div>
        <div class="p-4 pt-3">
          <p class="text-sm leading-relaxed text-psalm">
            El Oráculo Push or Fold, el Quiz del Pecador, y más artefactos sagrados.
            Calculadoras, tests y utilidades gratuitas para afilar tu juego.
          </p>
          <span class="mt-3 inline-flex items-center gap-1 text-xs font-medium text-gold/60 transition-all group-hover:gap-2 group-hover:text-gold">
            Explorar <span aria-hidden="true">→</span>
          </span>
        </div>
      </a>
    </div>
  </section>

  <!-- ===== SERMON INTRO ===== -->
  <section class="relative mx-auto max-w-3xl px-4 py-20 text-center">
    <!-- Ambient glow -->
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-[300px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-10" style="background: radial-gradient(circle, var(--color-gold) 0%, transparent 70%); filter: blur(80px);" aria-hidden="true"></div>

    <div class="relative">
      <p class="text-xs font-bold uppercase tracking-[0.25em] text-gold/60">Primer Sermón</p>
      <h2 class="mt-4 font-display text-2xl font-bold text-scripture sm:text-3xl lg:text-4xl">
        Si has llegado hasta aquí, es por algo
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-base leading-relaxed text-psalm">
        Quizá el river te ha tratado mal demasiadas veces y buscas respuestas.
        Quizá simplemente tienes curiosidad. En ambos casos, estás en el lugar correcto.
        Aquí no encontrarás contenido tibio ni fórmulas mágicas. Encontrarás la verdad desnuda
        del green felt, servida con humor y sin anestesia.
      </p>
      <div class="divider-sacred mt-10">
        <span class="text-sm text-whisper/60">♠ ♥ ♦ ♣</span>
      </div>
    </div>
  </section>
</BaseLayout>
