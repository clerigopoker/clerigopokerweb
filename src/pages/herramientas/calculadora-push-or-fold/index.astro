    // ║  +EV comparado con fold (no vs raise/fold strategy).           ║
    // ║                                                                 ║
    // ║  CÓMO MODIFICAR: Ajusta los números con datos de ICMIZER/HRC. ║
    // ║  Máximo = 169 (push any). Mínimo = 0 (fold everything).       ║
    // ╚══════════════════════════════════════════════════════════════════╝
    const PUSH_CUTOFFS = {
        // ── SB: Push vs BB solamente. Rango más amplio en todas las profundidades. ──
        SB: {
            1:169, 2:169, 3:158, 4:143, 5:130, 6:117, 7:105, 8:95,
            9:87,  10:80, 11:74, 12:68, 13:62, 14:57, 15:52, 16:48,
            17:44, 18:41, 19:38, 20:35, 21:33, 22:31, 23:29, 24:27, 25:25,
            26:23, 27:22, 28:20, 29:19, 30:18, 31:17, 32:16, 33:15,
            34:14, 35:13, 36:13, 37:12, 38:11, 39:11, 40:10
        },
        // ── BTN: Push sobre SB + BB. Segundo más amplio. ──
        BTN: {
            1:169, 2:165, 3:140, 4:120, 5:105, 6:93, 7:83, 8:75,
            9:68,  10:62, 11:57, 12:52, 13:48, 14:44, 15:40, 16:37,
            17:34, 18:32, 19:30, 20:28, 21:26, 22:24, 23:23, 24:22, 25:20,
            26:19, 27:18, 28:17, 29:16, 30:15, 31:14, 32:13, 33:12,
            34:12, 35:11, 36:10, 37:10, 38:9,  39:9,  40:8
        },
        // ── CO: Push sobre BTN + SB + BB. ──
        CO: {
            1:169, 2:155, 3:125, 4:105, 5:90, 6:78, 7:68, 8:60,
            9:54,  10:48, 11:44, 12:40, 13:37, 14:34, 15:31, 16:29,
            17:27, 18:25, 19:23, 20:22, 21:20, 22:19, 23:18, 24:17, 25:16,
            26:15, 27:14, 28:13, 29:12, 30:12, 31:11, 32:10, 33:10,
            34:9,  35:9,  36:8,  37:8,  38:7,  39:7,  40:6
        },
        // ── HJ: Push sobre CO + BTN + SB + BB. ──
        HJ: {
            1:165, 2:140, 3:110, 4:90, 5:76, 6:65, 7:56, 8:49,
            9:43,  10:38, 11:35, 12:32, 13:29, 14:27, 15:25, 16:23,
            17:21, 18:20, 19:19, 20:18, 21:17, 22:16, 23:15, 24:14, 25:13,
            26:12, 27:12, 28:11, 29:10, 30:10, 31:9,  32:9,  33:8,
            34:8,  35:7,  36:7,  37:6,  38:6,  39:6,  40:5
        },
        // ── UTG: Push sobre HJ + CO + BTN + SB + BB. Rango más tight. ──
        UTG: {
            1:155, 2:125, 3:95,  4:78, 5:65, 6:55, 7:47, 8:41,
            9:36,  10:32, 11:29, 12:26, 13:24, 14:22, 15:20, 16:19,
            17:18, 18:17, 19:16, 20:15, 21:14, 22:13, 23:12, 24:12, 25:11,
