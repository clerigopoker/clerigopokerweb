    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  ACTION MODIFIERS — Ajuste de rangos según acción previa        ║
    // ║                                                                 ║
    // ║  Cada acción previa tiene un multiplicador que se aplica al     ║
    // ║  cutoff base. El multiplicador puede variar según el stack.     ║
    // ║                                                                 ║
    // ║  foldToMe:     1.0  (rango base, sin modificación)              ║
    // ║  limper1:      Variable. Con pocos BB, el dead money extra del  ║
    // ║                limp incentiva push más amplio (~1.05-1.15x).    ║
    // ║                Con muchos BB, el riesgo de call lo compensa.    ║
    // ║  vsRaise:      ~0.45-0.60x. 3-bet shove es mucho más tight.   ║
    // ║                Solo manos premium vs un rango de apertura.      ║
    // ║  vsRaiseCaller: ~0.30-0.45x. Squeeze shove ultra-tight.       ║
    // ║                                                                 ║
    // ║  CÓMO MODIFICAR: Puedes reemplazar estos multiplicadores por   ║
    // ║  tablas completas de cutoff separadas (como PUSH_CUTOFFS pero  ║
    // ║  para cada escenario de acción) para máxima precisión.          ║
    // ║                                                                 ║
    // ║  Para datos exactos, usa ICMIZER/HRC con el escenario real:    ║
    // ║  - "Push over limp" con tamaño de bote ajustado                ║
    // ║  - "3-bet shove vs open" con tamaño de raise del oponente      ║
    // ║  - "Squeeze" con raise + call                                   ║
    // ╚══════════════════════════════════════════════════════════════════╝
    const ACTION_MODIFIERS = {
        // Fold to me: rango base sin cambios
        foldToMe: {
            getMultiplier: function(stack) { return 1.0; },
            label: 'Fold to me',
            emoji: '🟢',
            badgeClass: 'fold-to-me',
            hint: 'Rango estándar push-or-fold',
            matrixLabel: 'FOLD TO ME',
            pushLabel: 'PUSH All-in',
            color: '#10b981'
        },

        // 1 Limper: push over limp
        // Dead money extra (~1 BB) hace el push ligeramente más rentable
        // a stacks bajos. A stacks altos, el limper tiene un calling range
        // más amplio, reduciendo la fold equity.
        limper1: {
            getMultiplier: function(stack) {
                // Stacks muy cortos (1-5 BB): dead money pesa mucho → push más amplio
                if (stack <= 3)  return 1.15;
                if (stack <= 5)  return 1.12;
                if (stack <= 8)  return 1.08;
                if (stack <= 12) return 1.05;
                if (stack <= 18) return 1.00;
                if (stack <= 25) return 0.95;
                // Stacks altos: el limper probablemente tiene algo → más tight
                return 0.90;
            },
            label: '1 Limper',
            emoji: '🟡',
            badgeClass: 'limper',
            hint: 'Push over limp — dead money extra en el bote',
            matrixLabel: 'PUSH OVER LIMP',
            pushLabel: 'PUSH over Limp',
            color: '#eab308'
        },

        // Facing Raise: 3-bet shove
        // Mucho más tight. El raiser tiene un rango definido y fuerte.
        // A stacks bajos el push sigue siendo viable con buenas manos.
        // A stacks altos el riesgo de bust contra un rango de apertura
        // hace que solo manos premium sean rentables.
        vsRaise: {
            getMultiplier: function(stack) {
                if (stack <= 3)  return 0.70;
                if (stack <= 5)  return 0.62;
                if (stack <= 8)  return 0.55;
                if (stack <= 12) return 0.50;
                if (stack <= 18) return 0.45;
                if (stack <= 25) return 0.40;
                if (stack <= 32) return 0.35;
                return 0.30;
            },
            label: 'Facing Raise',
            emoji: '🔴',
            badgeClass: 'vs-raise',
            hint: '3-bet shove — push sobre un raise abierto',
            matrixLabel: '3-BET SHOVE',
            pushLabel: 'PUSH over Raise',
            color: '#ef4444'
        },

        // Raise + Caller: squeeze shove
        // Ultra tight. Enfrentas dos rangos. Solo manos super premium.
        vsRaiseCaller: {
            getMultiplier: function(stack) {
                if (stack <= 3)  return 0.55;
                if (stack <= 5)  return 0.48;
                if (stack <= 8)  return 0.42;
                if (stack <= 12) return 0.38;
                if (stack <= 18) return 0.33;
                if (stack <= 25) return 0.28;
