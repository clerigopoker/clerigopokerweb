    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  UTILIDADES                                                     ║
    // ╚══════════════════════════════════════════════════════════════════╝

    function getHandName(row, col) {
        if (row === col) return RANKS[row] + RANKS[col];
        if (row < col)  return RANKS[row] + RANKS[col] + 's';
        return RANKS[col] + RANKS[row] + 'o';
    }

    function getHandType(hand) {
        if (hand.length === 2) return 'pair';
        return hand.endsWith('s') ? 'suited' : 'offsuit';
    }

    function getCombos(hand) {
        const type = getHandType(hand);
        if (type === 'pair')   return 6;
        if (type === 'suited') return 4;
        return 12;
    }

    function getHandTypeLabel(hand) {
        const type = getHandType(hand);
        if (type === 'pair')   return 'Pareja';
        if (type === 'suited') return 'Suited (mismo palo)';
        return 'Offsuit (distinto palo)';
    }

    function getPushColor(rankIndex, cutoff, actionColor) {
        const ratio = rankIndex / Math.max(cutoff - 1, 1);
        // Use the action's hue for coloring
        const h = 158 - ratio * 12;
        const s = 78 - ratio * 15;
        const l = 24 + ratio * 20;
        return `hsl(${h}, ${s}%, ${l}%)`;
    }

    /**
     * Devuelve el color de push según la acción previa seleccionada.
     * Cada escenario tiene su propia paleta de colores para distinguir
     * visualmente el tipo de situación.
     */
    function getActionPushColor(rankIndex, cutoff, action) {
        const ratio = rankIndex / Math.max(cutoff - 1, 1);

        switch(action) {
            case 'foldToMe':
                // Verde estándar
                return `hsl(${158 - ratio*12}, ${78 - ratio*15}%, ${24 + ratio*20}%)`;
            case 'limper1':
                // Amarillo-verde
                return `hsl(${85 - ratio*10}, ${70 - ratio*12}%, ${26 + ratio*18}%)`;
            case 'vsRaise':
                // Rojo-naranja
                return `hsl(${12 - ratio*8}, ${72 - ratio*15}%, ${28 + ratio*16}%)`;
            case 'vsRaiseCaller':
                // Púrpura
                return `hsl(${280 - ratio*15}, ${60 - ratio*12}%, ${30 + ratio*14}%)`;
            default:
                return `hsl(${158 - ratio*12}, ${78 - ratio*15}%, ${24 + ratio*20}%)`;
        }
    }

    /**
     * Devuelve la zona de stack y su etiqueta
     */
    function getStackZone(stack) {
        if (stack <= 5)  return { label: 'Desperation', color: '#ef4444', emoji: '🔴' };
        if (stack <= 10) return { label: 'Short Stack', color: '#f97316', emoji: '🟠' };
        if (stack <= 20) return { label: 'Push/Fold Zone', color: '#eab308', emoji: '🟡' };
        if (stack <= 30) return { label: 'Comfortable', color: '#22c55e', emoji: '🟢' };
        return { label: 'Deep Stack', color: '#06b6d4', emoji: '🔵' };
    }

    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  GENERACIÓN DE LA MATRIZ                                        ║
    // ╚══════════════════════════════════════════════════════════════════╝

    let selectedCell = null;

    function generateMatrix() {
        const container = document.getElementById('matrix');
        container.innerHTML = '';

        const corner = document.createElement('div');
        corner.className = 'matrix-header corner';
        corner.textContent = '';
        container.appendChild(corner);

        for (let c = 0; c < 13; c++) {
            const hdr = document.createElement('div');
            hdr.className = 'matrix-header col-hdr';
            hdr.textContent = RANKS[c];
            container.appendChild(hdr);
        }

        for (let r = 0; r < 13; r++) {
            const rowHdr = document.createElement('div');
            rowHdr.className = 'matrix-header row-hdr';
            rowHdr.textContent = RANKS[r];
            container.appendChild(rowHdr);

            for (let c = 0; c < 13; c++) {
                const hand = getHandName(r, c);
                const type = getHandType(hand);

                const cell = document.createElement('div');
                cell.className = `hand-cell fold ${type}`;
                cell.dataset.hand = hand;
                cell.dataset.row = r;
                cell.dataset.col = c;
                cell.textContent = hand;

                cell.addEventListener('click', () => selectHand(cell, hand));
                container.appendChild(cell);
            }
        }
    }

    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  CÁLCULO Y ACTUALIZACIÓN DE UI                                  ║
    // ╚══════════════════════════════════════════════════════════════════╝

    let currentPushSet = new Set();
    let currentCutoff = 0;
    let currentAction = 'foldToMe';
    let currentStack = 10;
    let currentPosition = 'BTN';

    function calculate() {
        const position = document.getElementById('position').value;
        const action = document.getElementById('priorAction').value;
        let stack = parseInt(document.getElementById('stack').value) || 10;

        // Clamp stack to 1-40
        stack = Math.max(1, Math.min(MAX_STACK, stack));

        // Effective stack
        if (document.getElementById('useEffective').checked) {
            const effStack = parseInt(document.getElementById('effectiveStack').value) || stack;
            stack = Math.min(stack, Math.max(1, Math.min(MAX_STACK, effStack)));
        }

        currentAction = action;
        currentStack = stack;
        currentPosition = position;

        // Get base cutoff for this position + stack
        const baseCutoff = PUSH_CUTOFFS[position][stack] || 0;

        // Apply action modifier
        const actionMod = ACTION_MODIFIERS[action];
        const multiplier = actionMod.getMultiplier(stack);
        const adjustedCutoff = Math.round(baseCutoff * multiplier);

        // Clamp to valid range
        const cutoff = Math.max(0, Math.min(169, adjustedCutoff));
        currentCutoff = cutoff;

        // Build push set
        const pushSet = new Set();
        for (let i = 0; i < cutoff && i < HAND_RANKINGS.length; i++) {
            pushSet.add(HAND_RANKINGS[i]);
        }
        currentPushSet = pushSet;

        // Update UI
        updateMatrix(pushSet, cutoff, action);
        updateStats(pushSet, cutoff, position, stack, action);
        updateActionBadge(action);
        updateStackZone(stack);

        // Update selected hand info if one is selected
        if (selectedCell) {
            const hand = selectedCell.dataset.hand;
            updateHandInfo(hand);
        }
    }

    function updateMatrix(pushSet, cutoff, action) {
        const cells = document.querySelectorAll('.hand-cell');
        cells.forEach(cell => {
            const hand = cell.dataset.hand;
            const type = getHandType(hand);

            if (pushSet.has(hand)) {
                const rankIndex = HAND_RANKINGS.indexOf(hand);
                cell.className = `hand-cell push ${type}`;
                cell.style.backgroundColor = getActionPushColor(rankIndex, cutoff, action);
            } else {
                cell.className = `hand-cell fold ${type}`;
                cell.style.backgroundColor = '';
            }

            if (selectedCell && selectedCell.dataset.hand === hand) {
                cell.classList.add('selected');
            }
        });
    }

    function updateActionBadge(action) {
        const mod = ACTION_MODIFIERS[action];
        const badge = document.getElementById('actionBadge');
        const hint = document.getElementById('actionHint');
        const matrixLabel = document.getElementById('matrixActionLabel');

        badge.className = `action-badge ${mod.badgeClass}`;
        badge.textContent = `${mod.emoji} ${mod.label}`;
        hint.textContent = mod.hint;

        matrixLabel.className = `ml-2 action-badge ${mod.badgeClass} text-[0.55rem]`;
        matrixLabel.textContent = mod.matrixLabel;
    }

    function updateStackZone(stack) {
        const zone = getStackZone(stack);
        const label = document.getElementById('stackZoneLabel');
        label.textContent = `${zone.emoji} ${zone.label}`;
        label.style.color = zone.color;
    }

    function updateStats(pushSet, cutoff, position, stack, action) {
        let totalCombos = 0;
        pushSet.forEach(hand => { totalCombos += getCombos(hand); });

        const percentage = ((totalCombos / TOTAL_COMBOS) * 100).toFixed(1);
        const handsCount = pushSet.size;

        document.getElementById('statPercent').textContent = percentage + '%';
        document.getElementById('statCombos').textContent = totalCombos;
        document.getElementById('statHands').textContent = handsCount + '/169';

        document.getElementById('progressFill').style.width = percentage + '%';
        document.getElementById('progressLabel').textContent = percentage + '%';

        const posColors = { UTG:'#ef4444', HJ:'#eab308', CO:'#f97316', BTN:'#22c55e', SB:'#3b82f6' };
        const posNames  = { UTG:'Under The Gun', HJ:'Hijack', CO:'Cutoff', BTN:'Button', SB:'Small Blind' };
        const actionMod = ACTION_MODIFIERS[action];
        const multiplier = actionMod.getMultiplier(stack);
        const multiplierPct = Math.round(multiplier * 100);

        if (!selectedCell) {
            const infoEl = document.getElementById('handInfo');
            const zone = getStackZone(stack);
            const modifierNote = action === 'foldToMe' ? '' :
                `<div class="mt-2 flex items-center justify-center gap-1.5">
                    <span class="action-badge ${actionMod.badgeClass}">${actionMod.emoji} ${actionMod.label}</span>
                    <span class="text-[0.6rem] text-[#6A6A82]">×${multiplier.toFixed(2)} (${multiplierPct}% del rango base)</span>
                </div>`;

            infoEl.innerHTML = `
                <div class="flex items-center gap-2 mb-2">
                    <span class="inline-block w-3 h-3 rounded-full" style="background:${posColors[position]}"></span>
                    <span class="text-sm font-bold text-[#E0E0E8]">${position} — ${posNames[position]}</span>
                </div>
                <p class="text-2xl font-black stat-value mb-1">${stack} BB</p>
                <p class="text-[0.6rem] font-semibold mb-1" style="color:${zone.color}">${zone.emoji} ${zone.label}</p>
                <p class="text-xs text-[#8888A0]">
                    ${actionMod.pushLabel}: <strong style="color:${actionMod.color}">${handsCount}</strong> tipos de mano
                    (<strong style="color:${actionMod.color}">${totalCombos}</strong> combos, <strong style="color:${actionMod.color}">${percentage}%</strong>)
                </p>
                ${modifierNote}
                <p class="text-[0.6rem] text-[#6A6A82] mt-2 italic">Haz clic en una celda para ver detalles</p>
            `;
        }
    }

    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  SELECCIÓN DE MANO INDIVIDUAL                                   ║
    // ╚══════════════════════════════════════════════════════════════════╝

    function selectHand(cell, hand) {
        if (selectedCell) {
            selectedCell.classList.remove('selected');
        }

        if (selectedCell && selectedCell.dataset.hand === hand) {
            selectedCell = null;
            calculate();
            return;
        }

        selectedCell = cell;
        cell.classList.add('selected');
        updateHandInfo(hand);
    }

    function updateHandInfo(hand) {
        const infoEl = document.getElementById('handInfo');
        const isPush = currentPushSet.has(hand);
        const rankIndex = HAND_RANKINGS.indexOf(hand);
        const combos = getCombos(hand);
        const type = getHandType(hand);
        const typeLabel = getHandTypeLabel(hand);
        const actionMod = ACTION_MODIFIERS[currentAction];

        const actionColor = isPush ? actionMod.color : '#ef4444';
        const actionText  = isPush ? `✓ ${actionMod.pushLabel}` : '✗ FOLD';
        const actionBg    = isPush ? `${actionMod.color}18` : 'rgba(239,68,68,0.1)';

        // Show action context
        const actionContext = currentAction === 'foldToMe' ? '' :
            `<div class="mt-2">
                <span class="action-badge ${actionMod.badgeClass}">${actionMod.emoji} ${actionMod.label}</span>
            </div>`;

        // If fold, show what action would need for this hand to be a push
        let foldNote = '';
        if (!isPush) {
            // Check if this hand pushes in "fold to me" scenario
            const baseCutoff = PUSH_CUTOFFS[currentPosition][currentStack] || 0;
            if (rankIndex < baseCutoff && currentAction !== 'foldToMe') {
                foldNote = `<p class="text-[0.55rem] text-[#D4A847]/70 mt-2">⚠ Sería PUSH con "Fold to me"</p>`;
            }
        }

        infoEl.innerHTML = `
            <div class="text-3xl font-black mb-1" style="font-family:'JetBrains Mono',monospace; color:${actionColor}">
                ${hand}
            </div>
            <div class="inline-block px-3 py-1 rounded-full text-xs font-bold mb-2"
                 style="background:${actionBg}; color:${actionColor}; border:1px solid ${actionColor}30">
                ${actionText}
            </div>
            ${actionContext}
            <div class="w-full grid grid-cols-3 gap-2 text-center mt-2">
                <div>
                    <p class="text-[0.55rem] text-[#6A6A82] font-semibold uppercase">Tipo</p>
                    <p class="text-xs font-bold text-[#B0B0C0]">${typeLabel}</p>
                </div>
                <div>
                    <p class="text-[0.55rem] text-[#6A6A82] font-semibold uppercase">Combos</p>
                    <p class="text-xs font-bold text-[#B0B0C0]">${combos}</p>
                </div>
                <div>
                    <p class="text-[0.55rem] text-[#6A6A82] font-semibold uppercase">Ranking</p>
                    <p class="text-xs font-bold text-[#B0B0C0]">#${rankIndex + 1} / 169</p>
                </div>
            </div>
            ${foldNote}
        `;
    }

    // ╔══════════════════════════════════════════════════════════════════╗
    // ║  EVENT LISTENERS & INITIALIZATION                               ║
    // ╚══════════════════════════════════════════════════════════════════╝

    function init() {
        const positionEl      = document.getElementById('position');
        const priorActionEl   = document.getElementById('priorAction');
        const stackEl         = document.getElementById('stack');
        const stackSliderEl   = document.getElementById('stackSlider');
        const useEffectiveEl  = document.getElementById('useEffective');
        const effectiveEl     = document.getElementById('effectiveStack');
        const effectiveSlider = document.getElementById('effectiveSlider');
        const effectiveContainer = document.getElementById('effectiveContainer');

        // Sync stack input ↔ slider
        stackSliderEl.addEventListener('input', () => {
            stackEl.value = stackSliderEl.value;
            calculate();
        });
        stackEl.addEventListener('input', () => {
            let v = parseInt(stackEl.value) || 1;
            v = Math.max(1, Math.min(MAX_STACK, v));
            stackSliderEl.value = v;
            calculate();
        });

        // Sync effective stack input ↔ slider
        effectiveSlider.addEventListener('input', () => {
            effectiveEl.value = effectiveSlider.value;
            calculate();
        });
        effectiveEl.addEventListener('input', () => {
            let v = parseInt(effectiveEl.value) || 1;
            v = Math.max(1, Math.min(MAX_STACK, v));
            effectiveSlider.value = v;
            calculate();
        });

        // Toggle effective stack container
        useEffectiveEl.addEventListener('change', () => {
            effectiveContainer.classList.toggle('hidden', !useEffectiveEl.checked);
            calculate();
        });

        // Position change
        positionEl.addEventListener('change', calculate);

        // Prior Action change
        priorActionEl.addEventListener('change', calculate);

        // Generate the matrix
        generateMatrix();

        // Initial calculation
        calculate();
    }

    // Expose calculate globally for the button onclick
    window.calculate = calculate;

    // Run on DOM ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
    } else {
        init();
    }

})();

</script>
</BaseLayout>
