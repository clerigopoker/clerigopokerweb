---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';

const allPosts = await getCollection('estrategia', ({ data }) => !data.draft && data.category === 'postflop');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Estrategia Post-Flop"
  description="Guías de estrategia post-flop: lectura de board, c-bets, pot control y el arte de navegar las calles cuando ya hay cartas comunitarias."
>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[
      { name: 'Estrategia', url: '/estrategia' },
      { name: 'Post-Flop', url: '/estrategia/postflop' },
    ]} />
    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-scripture sm:text-5xl">
        ♠ Estrategia <span class="text-sacred">Post-Flop</span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-psalm">
        Donde la magia y el dolor ocurren. C-bets, pot control, lectura de texturas,
        y el arte de extraer valor cuando Dios te da la mano correcta.
      </p>
    </header>
    {posts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/estrategia/${post.id}`}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            difficulty={post.data.difficulty}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="card-altar text-center py-12">
        <p class="text-psalm text-lg">🕯️ Los primeros sermones post-flop están en camino...</p>
      </div>
    )}
  </section>
</BaseLayout>
