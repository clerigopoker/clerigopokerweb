---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';

const allPosts = await getCollection('estrategia', ({ data }) => !data.draft && data.category === 'torneos');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Estrategia de Torneos"
  description="Guías de estrategia para torneos de póker: ICM, burbuja, push or fold, mesa final y la guerra de desgaste donde solo sobrevive el más devoto."
>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[
      { name: 'Estrategia', url: '/estrategia' },
      { name: 'Torneos', url: '/estrategia/torneos' },
    ]} />
    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-scripture sm:text-5xl">
        ♠ Estrategia de <span class="text-sacred">Torneos</span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-psalm">
        ICM, burbuja, mesa final. La guerra de desgaste donde solo sobrevive el más devoto.
        Cada ficha es una oración y cada decisión es un acto de fe.
      </p>
    </header>
    {posts.length > 0 ? (
      <div class="grid gap-6 sm:grid-cols-2">
        {posts.map((post) => (
          <ArticleCard
            title={post.data.title}
            description={post.data.description}
            href={`/estrategia/${post.id}`}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            difficulty={post.data.difficulty}
            image={post.data.image}
          />
        ))}
      </div>
    ) : (
      <div class="card-altar text-center py-12">
        <p class="text-psalm text-lg">🕯️ Los primeros sermones de torneos están en camino...</p>
      </div>
    )}
  </section>
</BaseLayout>
