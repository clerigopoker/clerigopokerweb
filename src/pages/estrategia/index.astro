---
/**
 * /estrategia/index.astro — Landing page del silo Estrategia
 */
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import ArticleCard from '@/components/ArticleCard.astro';

const allPosts = await getCollection('estrategia', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="Estrategia de Póker"
  description="Los mandamientos tácticos del póker: pre-flop, post-flop, torneos y cash game. Guías profundas para devotos del green felt que buscan la iluminación estratégica."
>
  <section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
    <Breadcrumb items={[{ name: 'Estrategia', url: '/estrategia' }]} />

    <header class="mb-12">
      <h1 class="font-display text-4xl font-bold text-scripture sm:text-5xl">
        ♠ <span class="text-sacred">Estrategia</span>
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-psalm">
        Aquí se forjan los santos del green felt. Cada artículo es un versículo del evangelio táctico.
        Escoge tu camino de penitencia:
      </p>
    </header>

    <!-- Sub-categorías -->
    <div class="grid gap-6 sm:grid-cols-2 mb-16">
      <a href="/estrategia/preflop" class="card-altar group transition-all hover:border-gold/40 hover:-translate-y-1">
        <h2 class="font-display text-xl font-bold text-scripture group-hover:text-sacred">Pre-Flop</h2>
        <p class="mt-2 text-sm text-psalm">
          El génesis de cada mano. Ranges, 3-bets, y por qué foldear es un acto de fe supremo.
        </p>
      </a>
      <a href="/estrategia/postflop" class="card-altar group transition-all hover:border-gold/40 hover:-translate-y-1">
        <h2 class="font-display text-xl font-bold text-scripture group-hover:text-sacred">Post-Flop</h2>
        <p class="mt-2 text-sm text-psalm">
          Donde la magia (y el dolor) ocurre. C-bets, pot control, y el arte de leer texturas.
        </p>
      </a>
      <a href="/estrategia/torneos" class="card-altar group transition-all hover:border-gold/40 hover:-translate-y-1">
        <h2 class="font-display text-xl font-bold text-scripture group-hover:text-sacred">Torneos</h2>
        <p class="mt-2 text-sm text-psalm">
          ICM, burbuja, mesa final. La guerra de desgaste donde solo sobrevive el más devoto.
        </p>
      </a>
      <a href="/estrategia/cash-game" class="card-altar group transition-all hover:border-gold/40 hover:-translate-y-1">
        <h2 class="font-display text-xl font-bold text-scripture group-hover:text-sacred">Cash Game</h2>
        <p class="mt-2 text-sm text-psalm">
          Stacks profundos, decisiones profundas. El templo del jugador paciente y calculador.
        </p>
      </a>
    </div>

    <!-- Listado de artículos -->
    {posts.length > 0 ? (
      <div>
        <div class="divider-sacred mb-8">
          <span class="font-display text-sm font-semibold uppercase tracking-widest text-gold">
            Últimos Sermones
          </span>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          {posts.map((post) => (
            <ArticleCard
              title={post.data.title}
              description={post.data.description}
              href={`/estrategia/${post.id}`}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              difficulty={post.data.difficulty}
              image={post.data.image}
            />
          ))}
        </div>
      </div>
    ) : (
      <div class="card-altar text-center py-12">
        <p class="text-psalm text-lg">🕯️ Los primeros sermones estratégicos están en camino...</p>
      </div>
    )}
  </section>
</BaseLayout>
