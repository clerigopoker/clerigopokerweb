---
/**
 * CTAWpt.astro — CTA de afiliado WPT Global
 * 
 * EL ENLACE ES GLOBAL: cambia aquí → cambia en todo el sitio.
 * EL COPY ES FLEXIBLE: cada artículo puede pasar copy personalizado.
 * Si no pasa nada, usa el default.
 */

interface Props {
  /** Variante predefinida (se ignora si se pasan props custom) */
  variant?: 'default' | 'sermon' | 'confesion';
  /** Copy personalizado — sobreescribe la variante */
  customEyebrow?: string;
  customHeadline?: string;
  customBody?: string;
  customCta?: string;
}

const { variant = 'default', customEyebrow, customHeadline, customBody, customCta } = Astro.props;

// ============================================
// ENLACE GLOBAL — Cambiar aquí cambia todo el sitio
// ============================================
const AFFILIATE_URL = 'https://tracking.wptpartners.com/visit/?bta=35660&nci=8069';

const presets = {
  default: {
    eyebrow: 'La Redención te Espera',
    headline: '¿Listo para poner tu fe a prueba en las mesas?',
    body: 'Todo buen clérigo necesita un altar donde oficiar. WPT Global es donde los devotos del green felt buscan la redención… o al menos un bote decente. Entra, siéntate, y que las cartas decidan si eres santo o pecador.',
    cta: 'Pecar en las Mesas',
  },
  sermon: {
    eyebrow: 'Sermón del Domingo',
    headline: 'Las escrituras dicen: "Foldea y serás libre"',
    body: 'Pero a veces, hermano, hay que ir all-in con convicción. WPT Global tiene mesas para cada nivel de devoción. Desde el novicio que apenas distingue un flush de un straight, hasta el obispo que lee souls como versículos.',
    cta: 'Buscar la Redención',
  },
  confesion: {
    eyebrow: 'Confesionario Abierto',
    headline: 'Confiesa tus pecados pokeriles y empieza de nuevo',
    body: 'Todos hemos hecho un call vergonzoso a las 3 AM con J4 offsuit. No te juzgamos. En WPT Global puedes empezar una nueva vida. Nuevas mesas, nuevo bankroll, misma adicción sagrada.',
    cta: 'Iniciar mi Penitencia',
  },
};

const base = presets[variant];
const copy = {
  eyebrow: customEyebrow || base.eyebrow,
  headline: customHeadline || base.headline,
  body: customBody || base.body,
  cta: customCta || base.cta,
};
