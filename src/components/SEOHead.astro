---
/**
 * SEOHead.astro — Componente de cabecera SEO + Performance
 * Fonts: non-render-blocking via media="print" swap trick
 */
import {
  formatTitle,
  getCanonical,
  getImageURL,
  SITE,
  type SEOProps,
} from '@/utils/seo';

interface Props extends SEOProps {}

const {
  title,
  description = SITE.defaultDescription,
  canonical,
  image,
  type = 'website',
  pubDate,
  updatedDate,
  author = 'El Clérigo',
  noindex = false,
  tags = [],
} = Astro.props;

const pageTitle = formatTitle(title);
const pageCanonical = canonical || getCanonical(Astro.url.pathname);
const pageImage = image?.src ? getImageURL(image.src) : getImageURL(SITE.defaultImage);
const pageImageAlt = image?.alt || `${SITE.name} — Estrategia de Póker`;

const fontURL = 'https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=Outfit:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap';
---

<!-- Primary Meta Tags -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={author} />
<link rel="canonical" href={pageCanonical} />
<meta name="generator" content={Astro.generator} />

{noindex && <meta name="robots" content="noindex, nofollow" />}
{!noindex && <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

<!-- Language -->
<meta property="og:locale" content={SITE.locale} />
<link rel="alternate" hreflang="es" href={pageCanonical} />
<link rel="alternate" hreflang="x-default" href={pageCanonical} />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={pageCanonical} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={pageImage} />
<meta property="og:image:alt" content={pageImageAlt} />
<meta property="og:image:width" content={String(image?.width || 1200)} />
<meta property="og:image:height" content={String(image?.height || 630)} />
<meta property="og:site_name" content={SITE.name} />

{type === 'article' && pubDate && (
  <>
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={author} />
    {tags.map((tag) => <meta property="article:tag" content={tag} />)}
  </>
)}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content={SITE.twitterHandle} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={pageImage} />
<meta name="twitter:image:alt" content={pageImageAlt} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- 
  FONTS — Non-render-blocking loading
  1. Preconnect to Google Fonts origins (DNS + TLS ahead of time)
  2. Preload the CSS file itself (highest priority fetch, non-blocking)
  3. Load stylesheet with media="print" trick (non-blocking) + onload swap
  4. noscript fallback for no-JS
-->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preload" as="style" href={fontURL} />
<link
  rel="stylesheet"
  href={fontURL}
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link rel="stylesheet" href={fontURL} />
</noscript>

<!-- Theme color -->
<meta name="theme-color" content="#08080D" />
<meta name="msapplication-TileColor" content="#08080D" />
