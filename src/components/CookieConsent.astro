---
/**
 * CookieConsent.astro — Banner de consentimiento de cookies
 * Bloquea GTM hasta que el usuario acepte.
 * Personalidad del Clérigo en el copy.
 * Compatible con GDPR/RGPD.
 */
---

<div
  id="cookie-banner"
  class="fixed bottom-0 left-0 right-0 z-[999] hidden"
  role="dialog"
  aria-label="Consentimiento de cookies"
  aria-modal="false"
>
  <!-- Backdrop blur -->
  <div class="border-t border-chalice/20" style="background: rgba(8, 8, 13, 0.95); backdrop-filter: blur(20px);">
    <div class="mx-auto flex max-w-5xl flex-col gap-4 px-4 py-5 sm:flex-row sm:items-center sm:justify-between sm:px-6">
      
      <!-- Text -->
      <div class="max-w-2xl">
        <p class="text-sm leading-relaxed text-psalm">
          <span class="font-semibold text-gold">🍪 Confesión obligatoria:</span>
          usamos cookies para analizar cómo navegas por la parroquia (Google Analytics) y para que los enlaces de afiliado funcionen.
          No vendemos tus datos — ni siquiera al diablo.
          <a href="/politica-de-cookies" class="text-gold underline underline-offset-2 hover:text-gold-light">Leer más</a>.
        </p>
      </div>

      <!-- Buttons -->
      <div class="flex shrink-0 items-center gap-3">
        <button
          id="cookie-reject"
          class="rounded-lg px-4 py-2.5 text-xs font-medium text-whisper transition-all hover:bg-white/5 hover:text-psalm"
          style="border: 1px solid rgba(30, 30, 48, 0.6);"
        >
          Solo esenciales
        </button>
        <button
          id="cookie-accept"
          class="btn-communion !py-2.5 !px-5 !text-xs"
        >
          Aceptar todo
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var consent = localStorage.getItem('cp_cookie_consent');
    var banner = document.getElementById('cookie-banner');

    // Si ya consintió, cargar GTM directamente si aceptó
    if (consent === 'all') {
      loadGTM();
      return;
    }

    // Si rechazó, no hacer nada
    if (consent === 'essential') {
      return;
    }

    // Si no hay decisión, mostrar banner
    if (banner) banner.classList.remove('hidden');

    document.getElementById('cookie-accept')?.addEventListener('click', function() {
      localStorage.setItem('cp_cookie_consent', 'all');
      if (banner) banner.classList.add('hidden');
      loadGTM();
    });

    document.getElementById('cookie-reject')?.addEventListener('click', function() {
      localStorage.setItem('cp_cookie_consent', 'essential');
      if (banner) banner.classList.add('hidden');
    });

    function loadGTM() {
      // Dispara el evento para que Analytics.astro cargue GTM
      window.dispatchEvent(new CustomEvent('cookie-consent-granted'));
    }
  })();
</script>
