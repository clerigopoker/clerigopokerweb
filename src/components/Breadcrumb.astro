---
/**
 * Breadcrumb.astro — Migas de pan con Schema.org
 * Esencial para SEO y navegación de silos
 */
import { getBreadcrumbSchema } from '@/utils/seo';

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Siempre incluir Inicio al principio
const fullItems: BreadcrumbItem[] = [
  { name: 'Inicio', url: '/' },
  ...items,
];

const schemaJSON = getBreadcrumbSchema(fullItems);
---

<nav aria-label="Breadcrumb" class="mb-6">
  <ol class="flex flex-wrap items-center gap-1 text-sm text-whisper">
    {fullItems.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && (
          <span class="text-chalice" aria-hidden="true">›</span>
        )}
        {index === fullItems.length - 1 ? (
          <span class="text-psalm" aria-current="page">{item.name}</span>
        ) : (
          <a href={item.url} class="transition-colors hover:text-gold">
            {item.name}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>

<!-- Schema.org BreadcrumbList -->
<script type="application/ld+json" set:html={schemaJSON} />
