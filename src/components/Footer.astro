---
const currentYear = new Date().getFullYear();
---

<footer class="relative mt-24 border-t border-chalice/15" style="background: linear-gradient(180deg, var(--color-vestment) 0%, var(--color-abyss) 100%);">
  <!-- Top gold accent -->
  <div class="absolute top-0 left-[10%] right-[10%] h-px" style="background: linear-gradient(90deg, transparent, rgba(212, 168, 71, 0.15), transparent);"></div>

  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="group inline-flex items-center gap-2 text-scripture no-underline">
          <span class="flex h-8 w-8 items-center justify-center rounded-lg text-sm" style="background: linear-gradient(135deg, rgba(212,168,71,0.12), rgba(212,168,71,0.04)); border: 1px solid rgba(212,168,71,0.15);">✝</span>
          <span class="font-display text-sm font-bold tracking-[0.12em]">
            <span class="text-sacred">CLÉRIGO</span>
            <span class="text-psalm"> POKER</span>
          </span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-psalm">
          Donde la estrategia es religión y cada mano es un sermón.
          Bienvenido a la parroquia del green felt.
        </p>
      </div>

      <!-- Estrategia -->
      <div>
        <h3 class="font-display text-[0.6875rem] font-bold uppercase tracking-[0.2em] text-gold">Estrategia</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/estrategia/preflop" class="text-sm text-psalm transition-colors hover:text-scripture">Pre-Flop</a></li>
          <li><a href="/estrategia/postflop" class="text-sm text-psalm transition-colors hover:text-scripture">Post-Flop</a></li>
          <li><a href="/estrategia/torneos" class="text-sm text-psalm transition-colors hover:text-scripture">Torneos</a></li>
          <li><a href="/estrategia/cash-game" class="text-sm text-psalm transition-colors hover:text-scripture">Cash Game</a></li>
        </ul>
      </div>

      <!-- Psicología -->
      <div>
        <h3 class="font-display text-[0.6875rem] font-bold uppercase tracking-[0.2em] text-gold">Psicología</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/psicologia/tilt" class="text-sm text-psalm transition-colors hover:text-scripture">Tilt</a></li>
          <li><a href="/psicologia/mindset" class="text-sm text-psalm transition-colors hover:text-scripture">Mindset</a></li>
          <li><a href="/psicologia/bankroll-management" class="text-sm text-psalm transition-colors hover:text-scripture">Bankroll</a></li>
        </ul>
      </div>

      <!-- Comunidad -->
      <div>
        <h3 class="font-display text-[0.6875rem] font-bold uppercase tracking-[0.2em] text-gold">La Parroquia</h3>
        <ul class="mt-4 space-y-2.5">
          <li><a href="/noticias" class="text-sm text-psalm transition-colors hover:text-scripture">Noticias</a></li>
          <li><a href="/conceptos" class="text-sm text-psalm transition-colors hover:text-scripture">Conceptos</a></li>
          <li><a href="/herramientas" class="text-sm text-psalm transition-colors hover:text-scripture">Herramientas</a></li>
          <li><a href="/sobre" class="text-sm text-psalm transition-colors hover:text-scripture">Sobre el Clérigo</a></li>
        </ul>

        <!-- Social + Contact -->
        <div class="mt-6">
          <h3 class="font-display text-[0.6875rem] font-bold uppercase tracking-[0.2em] text-gold">Confiesa con Nosotros</h3>
          <div class="mt-4 flex items-center gap-3">
            <!-- Facebook -->
            <a href="https://www.facebook.com/ClerigoPoker/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="flex h-9 w-9 items-center justify-center rounded-lg transition-all duration-200 hover:-translate-y-0.5" style="background: rgba(212,168,71,0.06); border: 1px solid rgba(212,168,71,0.12);">
              <svg class="h-4 w-4 text-psalm transition-colors group-hover:text-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <!-- Instagram -->
            <a href="https://www.instagram.com/clerigopoker" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="flex h-9 w-9 items-center justify-center rounded-lg transition-all duration-200 hover:-translate-y-0.5" style="background: rgba(212,168,71,0.06); border: 1px solid rgba(212,168,71,0.12);">
              <svg class="h-4 w-4 text-psalm transition-colors group-hover:text-gold" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
