          </a>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3 text-xs text-psalm">
        <a href="/politica-de-privacidad" class="transition-colors hover:text-scripture">Privacidad</a>
        <span>·</span>
        <a href="/politica-de-cookies" class="transition-colors hover:text-scripture">Cookies</a>
        <span>·</span>
        <a href="/terminos-y-condiciones" class="transition-colors hover:text-scripture">Términos</a>
        <span>·</span>
        <span class="font-semibold text-gold">+18 · Juega con responsabilidad</span>
      </div>
    </div>

    <!-- Agency credit -->
    <div class="mt-8 text-center">
      <p class="text-[0.65rem] text-psalm">
        Arquitectura digital forjada por
        <a href="https://brújulamarketing.cl" target="_blank" rel="noopener noreferrer" class="text-gold transition-colors hover:text-scripture">
